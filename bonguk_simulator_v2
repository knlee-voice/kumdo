<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>本國劍法 · 본국검법 / 연무 시뮬레이터</title>
<style>
  :root {
    --bg-0: #0a0a0c;
    --bg-1: #131318;
    --bg-2: #1c1c24;
    --ink: #e8e6df;
    --ink-dim: #8a8780;
    --ink-faint: #4a4842;
    --rule: #2a2a32;
    --taegeuk-red: #c8233a;
    --taegeuk-blue: #2a4a8a;
    --gold: #b89968;
    --accent: #d4b87a;
    --hakama: #16161e;
    --hakama-fold: #0d0d12;
    --gi: #1f1f28;
    --sword-blade: #c8c4b8;
    --sword-hilt: #1a1410;
    --sword-tsuba: #6a5a40;
    --footprint: rgba(212, 184, 122, 0.55);
    --footprint-current: #d4b87a;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html, body {
    height: 100%;
    background: var(--bg-0);
    color: var(--ink);
    font-family: 'Noto Sans KR', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    overflow: hidden;
    -webkit-font-smoothing: antialiased;
  }

  .hanja {
    font-family: 'Noto Serif KR', 'Nanum Myeongjo', serif;
    letter-spacing: 0.06em;
  }

  /* ====== Layout ====== */
  .app {
    display: grid;
    grid-template-columns: 1fr 320px;
    grid-template-rows: 108px 60px 1fr 70px;
    height: 100vh;
    width: 100vw;
    gap: 1px;
    background: var(--rule);
  }

  header.title-bar {
    grid-column: 1 / -1;
    background: var(--bg-1);
    display: flex;
    align-items: center;
    padding: 0 24px;
    gap: 20px;
    border-bottom: 1px solid var(--rule);
  }
  header.title-bar .mark {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  header.title-bar .mark .hanja-title {
    font-family: 'Noto Serif KR', serif;
    font-size: 40px;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--accent);
  }
  header.title-bar .mark .ko-title {
    font-size: 35px;
    color: var(--ink-dim);
    letter-spacing: 0.2em;
  }
  header.title-bar .meta {
    margin-left: auto;
    font-size: 14px;
    color: var(--ink-faint);
    letter-spacing: 0.1em;
  }

  /* ====== Stage ====== */
  .stage {
    background: var(--bg-1);
    position: relative;
    overflow: hidden;
  }
  #stage-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Stage overlay: compass + cross-hairs */
  .stage-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .compass-box {
    position: absolute;
    bottom: 20px;
    left: 20px;
    width: 180px;
    background: rgba(10, 10, 12, 0.72);
    backdrop-filter: blur(8px);
    border: 1px solid var(--rule);
    padding: 10px 12px 12px;
    pointer-events: auto;
  }
  .compass-box .label {
    font-size: 12px;
    letter-spacing: 0.25em;
    color: var(--ink-faint);
    text-transform: uppercase;
    margin-bottom: 6px;
    display: flex;
    justify-content: space-between;
  }
  .compass-box .label .deg {
    color: var(--accent);
    letter-spacing: 0.1em;
  }
  #compass-canvas {
    display: block;
    width: 156px;
    height: 156px;
  }

  .stage-title-frame {
    grid-column: 1;
    background: var(--bg-1);
    border-bottom: 1px solid var(--rule);
    border-left: 2px solid var(--accent);
    display: flex;
    align-items: center;
    padding: 0 20px;
  }
  .stage-title-frame .hanja-name {
    color: var(--accent);
    font-family: 'Noto Serif KR', serif;
    font-size: 27px;
    letter-spacing: 0.15em;
  }

  .keyframe-tag {
    position: absolute;
    bottom: 20px;
    right: 20px;
    font-size: 12px;
    letter-spacing: 0.25em;
    color: var(--ink-faint);
    text-align: right;
  }
  .keyframe-tag .num {
    color: var(--accent);
    font-size: 30px;
    font-family: 'Noto Serif KR', serif;
    letter-spacing: 0;
    line-height: 1;
  }

  /* ====== Sidebar ====== */
  .sidebar {
    background: var(--bg-1);
    overflow-y: auto;
    grid-row: 2 / 5;
  }
  .sidebar-header {
    padding: 16px 20px 10px;
    border-bottom: 1px solid var(--rule);
    position: sticky;
    top: 0;
    background: var(--bg-1);
    z-index: 5;
  }
  .sidebar-header .h {
    font-size: 13px;
    letter-spacing: 0.3em;
    color: var(--ink-faint);
    text-transform: uppercase;
  }
  .sidebar-header .sub {
    font-family: 'Noto Serif KR', serif;
    color: var(--accent);
    font-size: 18px;
    margin-top: 2px;
    letter-spacing: 0.1em;
  }
  .sidebar-header .section-tabs {
    display: flex;
    gap: 0;
    margin-top: 10px;
    border-top: 1px solid var(--rule);
    padding-top: 8px;
  }
  .sidebar-header .section-tabs button {
    flex: 1;
    background: transparent;
    border: none;
    color: var(--ink-dim);
    font-size: 12px;
    letter-spacing: 0.2em;
    padding: 4px 0;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.15s;
  }
  .sidebar-header .section-tabs button.active {
    color: var(--accent);
  }
  .form-list {
    list-style: none;
  }
  .form-list li {
    padding: 15px 20px;
    border-bottom: 1px solid var(--rule);
    cursor: pointer;
    display: flex;
    align-items: flex-start;
    gap: 12px;
    transition: background 0.12s;
  }
  .form-list li:hover {
    background: var(--bg-2);
  }
  .form-list li.active {
    background: linear-gradient(90deg, rgba(212, 184, 122, 0.08), transparent);
    border-left: 2px solid var(--accent);
    padding-left: 18px;
  }
  .form-list li .num {
    font-family: 'Noto Serif KR', serif;
    color: var(--ink-faint);
    font-size: 15px;
    min-width: 26px;
    padding-top: 1px;
  }
  .form-list li.active .num {
    color: var(--accent);
  }
  .form-list li .names {
    flex: 1;
    min-width: 0;
  }
  .form-list li .names .ko {
    font-size: 15px;
    color: var(--ink);
    letter-spacing: 0.05em;
  }
  .form-list li .names .li-desc {
    font-size: 16px;
    color: var(--ink-dim);
    line-height: 1.6;
    margin-top: 6px;
    letter-spacing: 0.01em;
  }
  .form-list li.active .names .li-desc {
    color: var(--ink);
  }
  .form-list li .names .hj {
    font-family: 'Noto Serif KR', serif;
    font-size: 12px;
    color: var(--ink-faint);
    letter-spacing: 0.1em;
    margin-top: 1px;
  }
  .form-list li.section-divider {
    background: var(--bg-2);
    padding: 6px 20px;
    pointer-events: none;
    border-left: none;
  }
  .form-list li.section-divider .label {
    font-size: 12px;
    letter-spacing: 0.3em;
    color: var(--gold);
    font-family: 'Noto Serif KR', serif;
  }

  /* ====== Controls ====== */
  .controls {
    grid-column: 1 / 2;
    background: var(--bg-1);
    border-top: 1px solid var(--rule);
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    padding: 0 24px;
    gap: 12px;
  }
  .btn-group {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .ctrl-btn {
    background: transparent;
    border: 1px solid var(--rule);
    color: var(--ink);
    width: 40px;
    height: 40px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    font-family: inherit;
    font-size: 16px;
  }
  .ctrl-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .ctrl-btn.primary {
    background: var(--accent);
    color: var(--bg-0);
    border-color: var(--accent);
    width: 48px;
    height: 48px;
    font-size: 18px;
  }
  .ctrl-btn.primary:hover {
    background: var(--gold);
    color: var(--bg-0);
  }
  .progress-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .progress-bar {
    flex: 1;
    height: 4px;
    background: var(--rule);
    position: relative;
    cursor: pointer;
  }
  .progress-fill {
    height: 100%;
    background: var(--accent);
    width: 0%;
    transition: width 0.1s linear;
  }
  .progress-marks {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .progress-marks .mark {
    position: absolute;
    top: -3px;
    width: 1px;
    height: 10px;
    background: var(--ink-faint);
    opacity: 0.4;
  }
  .progress-marks .mark.section {
    background: var(--gold);
    opacity: 0.8;
    height: 14px;
    top: -5px;
  }
  .progress-label {
    font-size: 13px;
    letter-spacing: 0.15em;
    color: var(--ink-dim);
    font-family: 'Noto Serif KR', serif;
    min-width: 76px;
    text-align: right;
  }
  .progress-label .cur {
    color: var(--accent);
    font-size: 18px;
  }
  .speed-control {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--ink-dim);
    letter-spacing: 0.1em;
  }
  .speed-btn-group {
    display: flex;
    gap: 4px;
  }
  .speed-btn {
    background: transparent;
    color: var(--ink-dim);
    border: 1px solid var(--rule);
    padding: 6px 10px;
    font-family: inherit;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.15s;
  }
  .speed-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .speed-btn.active {
    background: var(--accent);
    color: var(--bg-0);
    border-color: var(--accent);
  }
  .loop-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--ink-dim);
    letter-spacing: 0.1em;
    cursor: pointer;
    user-select: none;
  }
  .loop-toggle input { cursor: pointer; accent-color: var(--accent); }

  /* ====== Description (removed) ====== */

  /* ====== Subtle background pattern ====== */
  .stage::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 50% 100%, rgba(212, 184, 122, 0.04), transparent 60%),
      linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.3) 100%);
    pointer-events: none;
    z-index: 1;
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg-1); }
  ::-webkit-scrollbar-thumb { background: var(--rule); }
  ::-webkit-scrollbar-thumb:hover { background: var(--ink-faint); }

  /* ============================================================
     반응형 레이아웃 설계 원칙

     기본(데스크탑 가로형):
       2열 그리드 - 좌(스테이지+제목바+컨트롤), 우(사이드바 320px)
       4행: 헤더(108) / 제목바(60) / 1fr(스테이지) / 컨트롤(70)
       사이드바는 grid-row: 2/5 (제목바+스테이지+컨트롤 높이)

     세로형 / 좁은 화면(aspect-ratio < 1 또는 모바일):
       1열 5행 세로 스택
       헤더 / 제목바 / 스테이지(고정 비율) / 사이드바 / 컨트롤

     판단 기준: aspect-ratio < 1 일 때 세로 스택 진입
     (단, 모바일 좁은 화면용 폰트/패딩 미세 조정은 별도 처리)
     ============================================================ */

  /* ====== 세로형 레이아웃 (PC 세로창 + 모바일 portrait 공통) ====== */
  @media (max-aspect-ratio: 1/1) {
    .app {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto minmax(38vh, 52vh) minmax(160px, 1fr) auto;
      height: 100vh;
      gap: 1px;
    }
    header.title-bar { grid-column: 1; grid-row: 1; }
    .stage-title-frame { grid-column: 1; grid-row: 2; }
    .stage { grid-column: 1; grid-row: 3; }
    .sidebar { grid-column: 1; grid-row: 4; max-height: none; }
    .controls {
      grid-column: 1;
      grid-row: 5;
      flex-wrap: wrap;
      padding: 10px 16px;
      gap: 8px 12px;
      height: auto;
    }
    .progress-wrap { order: 3; width: 100%; flex-basis: 100%; }
  }

  /* ====== 모바일 좁은 폭 미세조정 (스마트폰) ====== */
  @media (max-width: 600px) and (orientation: portrait) {
    .app {
      grid-template-rows: 48px 40px 42vh minmax(120px, 22vh) auto;
    }
    header.title-bar { padding: 0 12px; gap: 10px; }
    header.title-bar .mark .hanja-title { font-size: 24px; letter-spacing: 0.1em; }
    header.title-bar .mark .ko-title { font-size: 15px; letter-spacing: 0.1em; }
    header.title-bar .meta { display: none; }

    .stage-title-frame { padding: 0 12px; }
    .stage-title-frame .hanja-name { font-size: 14px; }

    .keyframe-tag { bottom: 10px; right: 10px; }
    .keyframe-tag .num { font-size: 20px; }
    .compass-box { bottom: 10px; left: 10px; width: 96px; padding: 6px 8px 8px; }
    #compass-canvas { width: 80px; height: 80px; }
    .compass-box .label { font-size: 8px; margin-bottom: 3px; }

    .sidebar-header { padding: 10px 14px 8px; }
    .form-list li { padding: 10px 14px; }

    .controls { padding: 8px 12px; gap: 8px 10px; }
    .ctrl-btn { width: 34px; height: 34px; font-size: 12px; }
    .ctrl-btn.primary { width: 40px; height: 40px; }
    .speed-control { font-size: 10px; }
    .progress-label { min-width: 60px; font-size: 10px; }
    .speed-btn { padding: 4px 6px; font-size: 11px; }
  }

  /* ====== PC 세로형 (601~1100px, 세로 비율) - 세로 스택 안에서 폰트 보정 ====== */
  @media (min-width: 601px) and (max-width: 1100px) and (max-aspect-ratio: 1/1) {
    .app {
      grid-template-rows: 80px 50px minmax(40vh, 50vh) minmax(180px, 1fr) auto;
    }
    .compass-box { width: 150px; }
    #compass-canvas { width: 130px; height: 130px; }
    .controls { padding: 10px 24px; gap: 10px 16px; }
  }

  /* ====== 가로형이지만 폭이 좁은 PC창(900px 이하) - 사이드바 폭 축소 ====== */
  @media (min-aspect-ratio: 1/1) and (max-width: 1100px) {
    .app {
      grid-template-columns: 1fr 260px;
    }
  }
</style>
</head>
<body>
<div class="app">
  <header class="title-bar">
    <div class="mark">
      <span class="hanja-title">本國劍法</span>
      <span class="ko-title">본국검법 / 연무 시뮬레이터</span>
    </div>
    <div class="meta">대한 검도 · 古劒譜 復原</div>
  </header>

  <div class="stage-title-frame">
    <span class="hanja-name" id="tag-hanja-main">持劒對賊勢 (지검대적세)</span>
  </div>

  <div class="stage">
    <canvas id="stage-canvas"></canvas>
    <div class="stage-overlay">
      <div class="keyframe-tag">
        <div><span class="num" id="tag-num">01</span> <span style="opacity:0.5">/ <span id="tag-total">33</span></span></div>
        <div style="margin-top:4px" id="tag-phase">初章 · 초장</div>
      </div>
    </div>
  </div>

  <aside class="sidebar">
    <div class="sidebar-header">
      <div class="sub">동작 목록</div>
    </div>
    <ul class="form-list" id="form-list"></ul>
  </aside>

  <div class="controls">
    <div class="btn-group">
      <button class="ctrl-btn" id="btn-first" title="처음으로">⏮</button>
      <button class="ctrl-btn" id="btn-prev" title="이전 동작">◀</button>
      <button class="ctrl-btn primary" id="btn-play" title="재생/정지">▶</button>
      <button class="ctrl-btn" id="btn-next" title="다음 동작">▶</button>
      <button class="ctrl-btn" id="btn-last" title="마지막">⏭</button>
    </div>

    <div class="progress-wrap">
      <div class="progress-bar" id="progress-bar">
        <div class="progress-fill" id="progress-fill"></div>
        <div class="progress-marks" id="progress-marks"></div>
      </div>
      <div class="progress-label">
        <span class="cur" id="progress-cur">01</span> / <span id="progress-total">33</span>
      </div>
    </div>

    <label class="loop-toggle" style="margin-left: 8px;">
      <input type="checkbox" id="loop-toggle" checked>
      <span>LOOP</span>
    </label>

    <div class="speed-control">
      <span>SPEED</span>
      <div class="speed-btn-group" id="speed-btn-group">
        <button class="speed-btn" data-speed="0.5">0.5×</button>
        <button class="speed-btn" data-speed="0.75">0.75×</button>
        <button class="speed-btn active" data-speed="1">1.0×</button>
        <button class="speed-btn" data-speed="1.5">1.5×</button>
        <button class="speed-btn" data-speed="2">2.0×</button>
      </div>
    </div>
  </div>


<script>
/* ====================================================================
   본국검법 시뮬레이터
   - 측면 뷰: 인물은 항상 오른쪽을 향해 표시 (자세 식별 최적화)
   - 나침반 뷰: 실제 방위(facing)와 발걸음 트레일을 별도 표시
   - 키프레임 보간 애니메이션
   ==================================================================== */

// ----- 포즈 프리셋: 관절은 hip(엉덩이) 기준 상대 좌표 (px) -----
// 인물은 오른쪽(facing right)을 향해 서 있는 측면 도식
// 좌표계: +x = 인물의 앞(오른쪽), -x = 뒤, +y = 아래
// 인물의 신체 부위 명칭은 "앞쪽(front)"과 "뒤쪽(back)"으로 통일 (carrera-style):
//   - frontShoulder: 카메라에 가까운 어깨 → 측면 뷰에서 잘 보이는 쪽
//   - backShoulder: 카메라에서 멀리 있는 어깨
// 단, 한국검법 동작 설명에서 "왼발/오른발"이 자주 등장하므로,
// 인물이 오른쪽으로 향할 때:
//   - 앞발(front foot) = 오른발, 뒷발(back foot) = 왼발 (대부분의 경우)
// 회전 시에는 facing 각도로 처리

const POSE = {
  // 기본 시작 자세: 칼을 왼쪽으로 들고 양발 평행
  start: {
    head: {x: 0, y: -150},
    neck: {x: 0, y: -130},
    chest: {x: 0, y: -90},
    hip: {x: 0, y: 0},
    // 어깨
    frontShoulder: {x: 8, y: -120},
    backShoulder:  {x: -8, y: -120},
    // 팔 (앞=오른팔, 뒤=왼팔, 인물 기준)
    frontElbow: {x: 18, y: -75},
    frontHand:  {x: 28, y: -30},
    backElbow:  {x: -2, y: -80},
    backHand:   {x: -10, y: -35},
    // 다리: 발은 hip 기준
    frontFoot: {x: 10, y: 0},
    backFoot:  {x: -10, y: 0},
    frontKnee: {x: 8, y: -2}, // legs hidden by hakama
    backKnee:  {x: -8, y: -2},
    // 칼
    swordGrip: 'left-side-low', // 'both' | 'right' | 'left' | 'left-armpit' | 'left-side-low' | 'sheath'
    swordOrigin: 'frontHand',   // 어느 손에서 시작
    swordAngle: -100,            // 칼 각도 (deg, 0=오른쪽, -90=위, 180=왼쪽)
    swordLength: 95,
    leanX: 0,
    leanY: 0,
  },

  // 중단세 (앞발=오른발)
  chudan_right_forward: {
    head: {x: 0, y: -150},
    neck: {x: 0, y: -130},
    chest: {x: 0, y: -90},
    hip: {x: 0, y: 0},
