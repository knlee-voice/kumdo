// 모든 동작의 누적 이동을 기록해 나침반에 트레일로 표시
// ====================================================================
function computeFootTrail() {
  // 단순화: 각 동작에서 인물이 facing 방향으로 약 1.5 보 전진한다고 가정
  // 회전만 하는 동작은 위치는 그대로
  const trail = [{x: 0, y: 0, facing: FORMS[0].keyframes[0].facing}];
  let x = 0, y = 0;
  for (let i = 0; i < FORMS.length; i++) {
    const f = FORMS[i];
    const startFacing = f.keyframes[0].facing;
    const endFacing = f.keyframes[f.keyframes.length - 1].facing;
    // 진전, 후일, 향전 같은 단어가 있으면 전진
    const goesForward = /진전|후일|장교|용약|시우|향전|향후|향우|발초/.test(f.nameKo);
    const moveDist = goesForward ? 30 : 8;
    const rad = endFacing * Math.PI / 180;
    x += Math.cos(rad) * moveDist;
    y += Math.sin(rad) * moveDist;
    trail.push({x, y, facing: endFacing});
  }
  return trail;
}
const FOOT_TRAIL = computeFootTrail();

