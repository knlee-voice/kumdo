const stageCanvas = document.getElementById('stage-canvas');
const stageCtx = stageCanvas.getContext('2d');

function resizeStage() {
  const dpr = window.devicePixelRatio || 1;
  const rect = stageCanvas.getBoundingClientRect();
  stageCanvas.width = rect.width * dpr;
  stageCanvas.height = rect.height * dpr;
  stageCtx.setTransform(dpr, 0, 0, dpr, 0, 0);
}
window.addEventListener('resize', resizeStage);
setTimeout(resizeStage, 0);

// ----- 보간 헬퍼 -----
function lerp(a, b, t) { return a + (b - a) * t; }
function lerpPoint(a, b, t) { return { x: lerp(a.x, b.x, t), y: lerp(a.y, b.y, t) }; }
function lerpAngle(a, b, t) {
  // 최단 경로 보간
  let diff = b - a;
  while (diff > 180) diff -= 360;
  while (diff < -180) diff += 360;
  return a + diff * t;
}
function easeInOutCubic(t) {
  return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
}

function interpolatePose(p1, p2, t) {
  const e = easeInOutCubic(t);
  const result = {};
  const pointKeys = ['head','neck','chest','hip','frontShoulder','backShoulder',
    'frontElbow','frontHand','backElbow','backHand',
    'frontFoot','backFoot','frontKnee','backKnee'];
  for (const k of pointKeys) {
    result[k] = lerpPoint(p1[k], p2[k], e);
  }
  result.swordAngle = lerpAngle(p1.swordAngle, p2.swordAngle, e);
  result.swordLength = lerp(p1.swordLength, p2.swordLength, e);
  result.leanX = lerp(p1.leanX, p2.leanX, e);
  result.leanY = lerp(p1.leanY, p2.leanY, e);
  // 그립과 origin: 50% 지점에서 전환
  result.swordGrip = e < 0.5 ? p1.swordGrip : p2.swordGrip;
  result.swordOrigin = e < 0.5 ? p1.swordOrigin : p2.swordOrigin;
  return result;
}

function resolveKeyframePose(kf) {
  if (typeof kf.pose === 'string') return POSE[kf.pose];
  return kf.pose;
}

function getCurrentPose(formIdx, formT) {
  const form = FORMS[formIdx];
  const kfs = form.keyframes;
  // 첫 키프레임 이전
  if (formT <= kfs[0].t) return { pose: resolveKeyframePose(kfs[0]), facing: kfs[0].facing };
  // 마지막 키프레임 이후
  if (formT >= kfs[kfs.length-1].t) {
    return { pose: resolveKeyframePose(kfs[kfs.length-1]), facing: kfs[kfs.length-1].facing };
  }
  // 사이 보간
  for (let i = 0; i < kfs.length - 1; i++) {
    if (formT >= kfs[i].t && formT <= kfs[i+1].t) {
      const localT = (formT - kfs[i].t) / (kfs[i+1].t - kfs[i].t);
      const pose = interpolatePose(resolveKeyframePose(kfs[i]), resolveKeyframePose(kfs[i+1]), localT);
      const facing = lerpAngle(kfs[i].facing, kfs[i+1].facing, easeInOutCubic(localT));
      return { pose, facing };
    }
  }
  return { pose: resolveKeyframePose(kfs[0]), facing: kfs[0].facing };
}

// ----- 인물 그리기 (측면 뷰, 항상 오른쪽 향함) -----
function drawFigure(ctx, cx, cy, pose, scale = 1) {
  ctx.save();
  ctx.translate(cx, cy);
  ctx.scale(scale, scale);

  // 좌표 변환: pose는 hip 기준
  // 측면 뷰에서 우리가 보는 인물은 오른쪽을 향함
  const hipX = pose.hip.x + pose.leanX;
  const hipY = pose.hip.y + pose.leanY;

  // === 뒷다리 (들렸을 때만 보임) — 하카마 뒤에 위치 ===
  drawHakamaLeg(ctx, hipX, hipY, pose.backKnee, pose.backFoot, 'back');

  // === 하카마 본체 (몸통과 다리 윗부분 가리는 큰 사다리꼴) ===
  drawHakamaBody(ctx, hipX, hipY, pose);

  // === 뒷발 (하카마 위, 앞발 아래) — 발등이 보이도록 ===
  drawFoot(ctx, pose.backFoot, true);

  // === 앞다리 (들렸을 때만 보임) ===
  drawHakamaLeg(ctx, hipX, hipY, pose.frontKnee, pose.frontFoot, 'front');

  // === 앞발 (가장 위) ===
  drawFoot(ctx, pose.frontFoot, false);

  // === 상의 (Gi/저고리) ===
  drawGi(ctx, pose);

  // === 머리 ===
  ctx.fillStyle = '#e8d8c0';
  ctx.beginPath();
  ctx.arc(pose.head.x, pose.head.y, 14, 0, Math.PI * 2);
  ctx.fill();
  ctx.strokeStyle = '#3a2a1a';
  ctx.lineWidth = 1;
  ctx.stroke();

  // 머리카락 (위쪽 절반)
  ctx.fillStyle = '#1a0f08';
  ctx.beginPath();
  ctx.arc(pose.head.x, pose.head.y - 3, 13, Math.PI, 0);
  ctx.fill();
  // 옆머리/구레나룻
  ctx.beginPath();
  ctx.moveTo(pose.head.x - 12, pose.head.y - 2);
  ctx.lineTo(pose.head.x - 11, pose.head.y + 6);
  ctx.lineTo(pose.head.x - 8, pose.head.y + 4);
  ctx.closePath();
  ctx.fill();

  // 얼굴 방향 표시: 코/턱 (오른쪽 향함)
  ctx.fillStyle = '#d8c8b0';
  ctx.beginPath();
  ctx.moveTo(pose.head.x + 13, pose.head.y + 2);
  ctx.lineTo(pose.head.x + 16, pose.head.y + 4);
  ctx.lineTo(pose.head.x + 12, pose.head.y + 6);
  ctx.closePath();
  ctx.fill();
  // 눈
  ctx.fillStyle = '#1a0f08';
  ctx.beginPath();
  ctx.arc(pose.head.x + 7, pose.head.y + 1, 1.2, 0, Math.PI * 2);
  ctx.fill();

  // === 뒤쪽 팔 ===
  drawArm(ctx, pose.backShoulder, pose.backElbow, pose.backHand, 'back');

  // === 칼 (앞쪽 그립 기준) ===
  drawSword(ctx, pose);

  // === 앞쪽 팔 (칼 위에 그려서 자연스럽게) ===
  drawArm(ctx, pose.frontShoulder, pose.frontElbow, pose.frontHand, 'front');

  ctx.restore();
}

function drawHakamaBody(ctx, hipX, hipY, pose) {
  // 하카마: 허리(hip)에서 시작해 발 쪽으로 갈수록 넓어지는 사다리꼴
  const lf = pose.frontFoot;
  const bf = pose.backFoot;
  const hakamaTopHalfWidth = 24;
  // 밑단을 발 위쪽으로 올려서 발등이 옷자락 밑으로 노출되도록
  const hakamaBottomY = Math.max(lf.y, bf.y, 0) - 5;
  // 좌우 폭: 발 위치를 넉넉히 넘어서 넓게
  const leftX = Math.min(lf.x, bf.x) - 22;
  const rightX = Math.max(lf.x, bf.x) + 22;

  // 하카마 본체
  ctx.fillStyle = '#16161e';
  ctx.beginPath();
  ctx.moveTo(hipX - hakamaTopHalfWidth, hipY - 10);
  ctx.lineTo(hipX + hakamaTopHalfWidth, hipY - 10);
  ctx.lineTo(rightX, hakamaBottomY);
  ctx.lineTo(leftX, hakamaBottomY);
  ctx.closePath();
  ctx.fill();

  // 옆선 음영 (하카마 깊이감)
  const grad = ctx.createLinearGradient(leftX, 0, rightX, 0);
  grad.addColorStop(0, 'rgba(0,0,0,0.5)');
  grad.addColorStop(0.5, 'rgba(0,0,0,0)');
  grad.addColorStop(1, 'rgba(0,0,0,0.5)');
  ctx.fillStyle = grad;
  ctx.beginPath();
  ctx.moveTo(hipX - hakamaTopHalfWidth, hipY - 10);
  ctx.lineTo(hipX + hakamaTopHalfWidth, hipY - 10);
  ctx.lineTo(rightX, hakamaBottomY);
  ctx.lineTo(leftX, hakamaBottomY);
  ctx.closePath();
  ctx.fill();

  // 주름 (수직 라인, 사다리꼴 비율 반영)
  ctx.strokeStyle = '#0a0a10';
  ctx.lineWidth = 1;
  const numPleats = 5;
  for (let i = 1; i < numPleats; i++) {
    const r = i / numPleats;
    const xTop = (hipX - hakamaTopHalfWidth) + 2 * hakamaTopHalfWidth * r;
    const xBot = leftX + (rightX - leftX) * r;
    ctx.beginPath();
    ctx.moveTo(xTop, hipY - 7);
    ctx.lineTo(xBot, hakamaBottomY - 2);
    ctx.stroke();
  }

  // 허리 띠
  ctx.fillStyle = '#0a0a10';
  ctx.fillRect(hipX - hakamaTopHalfWidth - 2, hipY - 14, hakamaTopHalfWidth * 2 + 4, 6);
  // 띠 매듭 (앞쪽으로)
  ctx.fillStyle = '#0a0a10';
  ctx.fillRect(hipX + 6, hipY - 16, 12, 10);
}

function drawHakamaLeg(ctx, hipX, hipY, knee, foot, side) {
  // 다리는 거의 보이지 않음 (하카마에 가려짐). 들렸을 때만 무릎-발 라인 표시.
  // 발 자체는 drawFigure에서 별도 z-순서로 렌더링.
  const lifted = foot.y < -10;
  if (lifted) {
    // 들린 다리: 무릎-발 라인을 하카마 색으로 그림 (확장된 옷자락처럼)
    ctx.strokeStyle = '#16161e';
    ctx.lineWidth = 18;
    ctx.lineCap = 'round';
    ctx.beginPath();
    ctx.moveTo(hipX, hipY - 8);
    ctx.lineTo(knee.x, knee.y);
    ctx.lineTo(foot.x, foot.y);
    ctx.stroke();
    // 주름 음영
    ctx.strokeStyle = '#0a0a10';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(hipX + 4, hipY - 6);
    ctx.lineTo(knee.x + 2, knee.y);
    ctx.lineTo(foot.x + 1, foot.y);
    ctx.stroke();
  }
}

function drawFoot(ctx, foot, isBack) {
  ctx.save();
  // 약간 위에서 내려다보는 시점 — 발등이 보이도록 둥근 타원으로 렌더링
  // 뒷발: 살짝 작고 약간 어둡게 (원근감)
  const dy = isBack ? -1.5 : 0;
  const wx = isBack ? 8.5 : 10;
  const wy = isBack ? 5 : 6;

  // 발 본체 (버선/맨발)
  ctx.fillStyle = isBack ? '#d6c4a8' : '#e8d8c0';
  ctx.strokeStyle = '#3a2a1a';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.ellipse(foot.x, foot.y - wy + 1 + dy, wx, wy, 0, 0, Math.PI * 2);
  ctx.fill();
  ctx.stroke();

  // 발등 하이라이트 (위쪽 둥글게 — 입체감)
  ctx.fillStyle = isBack ? 'rgba(255, 248, 230, 0.18)' : 'rgba(255, 248, 230, 0.28)';
  ctx.beginPath();
  ctx.ellipse(foot.x - 1, foot.y - wy - 0.5 + dy, wx * 0.6, wy * 0.45, 0, 0, Math.PI * 2);
  ctx.fill();

  // 발가락 구분선 (앞쪽 끝, 진행방향 우측)
  ctx.strokeStyle = '#7a6a5a';
  ctx.lineWidth = 0.6;
  ctx.beginPath();
  ctx.moveTo(foot.x + wx * 0.45, foot.y - wy - 0.5 + dy);
  ctx.lineTo(foot.x + wx * 0.7, foot.y - wy * 0.3 + dy);
  ctx.stroke();

  ctx.restore();
}

function drawGi(ctx, pose) {
  // 상의: 어깨 - 가슴 - 허리 라인
  const ls = pose.frontShoulder;
  const rs = pose.backShoulder;
  const chest = pose.chest;
  const hip = pose.hip;
  const hipX = hip.x + pose.leanX;
  const hipY = hip.y + pose.leanY;

  ctx.fillStyle = '#1f1f28';
  ctx.beginPath();
  ctx.moveTo(rs.x - 4, rs.y - 2);    // 뒤어깨 바깥
  ctx.lineTo(rs.x + 2, rs.y + 4);
  ctx.lineTo(chest.x - 18, chest.y);  // 가슴 뒤
  ctx.lineTo(hipX - 22, hipY - 8);   // 허리 뒤
  ctx.lineTo(hipX + 22, hipY - 8);   // 허리 앞
  ctx.lineTo(chest.x + 18, chest.y); // 가슴 앞
  ctx.lineTo(ls.x - 2, ls.y + 4);
  ctx.lineTo(ls.x + 4, ls.y - 2);    // 앞어깨 바깥
  ctx.lineTo(ls.x + 2, ls.y + 8);    // 옷깃
  ctx.lineTo(chest.x + 8, chest.y + 4);
  ctx.lineTo(chest.x, chest.y + 12);
  ctx.lineTo(chest.x - 6, chest.y + 4);
  ctx.lineTo(rs.x - 2, rs.y + 8);
  ctx.closePath();
  ctx.fill();

  // 옷깃 (V자 라인)
  ctx.strokeStyle = '#3a3a48';
  ctx.lineWidth = 1.5;
  ctx.beginPath();
  ctx.moveTo(ls.x + 2, ls.y + 8);
  ctx.lineTo(chest.x, chest.y + 12);
  ctx.lineTo(rs.x - 2, rs.y + 8);
  ctx.stroke();
}

function drawArm(ctx, shoulder, elbow, hand, side) {
  // 팔: 어깨-팔꿈치-손까지의 굵은 라인 (옷소매)
  ctx.strokeStyle = side === 'back' ? '#15151c' : '#1f1f28';
  ctx.lineWidth = 14;
  ctx.lineCap = 'round';
  ctx.lineJoin = 'round';
  ctx.beginPath();
  ctx.moveTo(shoulder.x, shoulder.y);
  ctx.lineTo(elbow.x, elbow.y);
  ctx.lineTo(hand.x, hand.y);
  ctx.stroke();

  // 음영
  ctx.strokeStyle = '#0a0a12';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(shoulder.x + 1, shoulder.y + 4);
  ctx.lineTo(elbow.x + 1, elbow.y + 1);
  ctx.lineTo(hand.x + 1, hand.y - 1);
  ctx.stroke();

  // 손 (작은 살색 점)
  ctx.fillStyle = '#e8d8c0';
  ctx.beginPath();
  ctx.arc(hand.x, hand.y, 4, 0, Math.PI * 2);
  ctx.fill();
}

function drawSword(ctx, pose) {
  // 칼의 시작점과 각도 결정
  let gripPoint;
  if (pose.swordGrip === 'sheath') {
    // 납검 자세: 왼쪽 옆구리에 꽂힘
    gripPoint = { x: pose.hip.x + pose.leanX - 18, y: pose.hip.y + pose.leanY - 8 };
  } else if (pose.swordGrip === 'left-armpit') {
    // 왼쪽 겨드랑이: 앞손은 자루 끝, 칼은 옆구리 뒤쪽으로
    gripPoint = pose.frontHand;
  } else if (pose.swordGrip === 'left-side-low') {
    // 시작 자세: 왼쪽으로 칼 들음
    gripPoint = pose.frontHand;
  } else {
    // both / right / left: 앞손이 기준
    gripPoint = pose.frontHand;
  }

  const angleRad = pose.swordAngle * Math.PI / 180;
  const len = pose.swordLength;
  const tipX = gripPoint.x + Math.cos(angleRad) * len;
  const tipY = gripPoint.y + Math.sin(angleRad) * len;
  // 자루 끝 (반대 방향으로 약 20px)
  const pommelX = gripPoint.x - Math.cos(angleRad) * 18;
  const pommelY = gripPoint.y - Math.sin(angleRad) * 18;

  // 자루 (검은색)
  ctx.strokeStyle = '#1a1410';
  ctx.lineWidth = 5;
  ctx.lineCap = 'square';
  ctx.beginPath();
  ctx.moveTo(pommelX, pommelY);
  ctx.lineTo(gripPoint.x, gripPoint.y);
  ctx.stroke();

  // 코등이 (tsuba)
  const tsubaPerpX = -Math.sin(angleRad) * 6;
  const tsubaPerpY = Math.cos(angleRad) * 6;
  ctx.fillStyle = '#6a5a40';
  ctx.beginPath();
  ctx.ellipse(gripPoint.x, gripPoint.y, 7, 3,
    Math.atan2(tsubaPerpY, tsubaPerpX), 0, Math.PI * 2);
  ctx.fill();

  // 칼날 (실검 - 직선)
  // 본국검법은 직검(直劍)이지만 시각적으로 약간 곡률 줘서 한국 검 느낌
  ctx.strokeStyle = '#c8c4b8';
  ctx.lineWidth = 3.5;
  ctx.lineCap = 'butt';
  ctx.beginPath();
  ctx.moveTo(gripPoint.x + Math.cos(angleRad) * 4, gripPoint.y + Math.sin(angleRad) * 4);
  ctx.lineTo(tipX, tipY);
  ctx.stroke();

  // 칼날 하이라이트
  ctx.strokeStyle = '#f5f1e8';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(gripPoint.x + Math.cos(angleRad) * 4 + tsubaPerpX * 0.15,
            gripPoint.y + Math.sin(angleRad) * 4 + tsubaPerpY * 0.15);
  ctx.lineTo(tipX + tsubaPerpX * 0.15, tipY + tsubaPerpY * 0.15);
  ctx.stroke();

  // 칼끝 (kissaki) - 작은 삼각
  ctx.fillStyle = '#a8a496';
  ctx.beginPath();
  ctx.moveTo(tipX, tipY);
  ctx.lineTo(tipX - Math.cos(angleRad) * 6 + tsubaPerpX * 0.3,
            tipY - Math.sin(angleRad) * 6 + tsubaPerpY * 0.3);
  ctx.lineTo(tipX - Math.cos(angleRad) * 6 - tsubaPerpX * 0.3,
            tipY - Math.sin(angleRad) * 6 - tsubaPerpY * 0.3);
  ctx.closePath();
  ctx.fill();
}

// ----- 무대(stage) 배경 그리기 -----
function drawStageBackground(ctx, w, h) {
  // 그라데이션 바닥
  const grad = ctx.createLinearGradient(0, h * 0.45, 0, h);
  grad.addColorStop(0, '#1c1c24');
  grad.addColorStop(1, '#0a0a0c');
  ctx.fillStyle = grad;
  ctx.fillRect(0, h * 0.45, w, h * 0.55);

  // 위쪽 배경 (벽)
  ctx.fillStyle = '#131318';
  ctx.fillRect(0, 0, w, h * 0.45);

  // 바닥선 (마룻바닥 라인)
  ctx.strokeStyle = '#2a2a32';
  ctx.lineWidth = 1;
  for (let i = 0; i < 8; i++) {
    const y = h * 0.45 + (h * 0.55) * (i / 8) * (i / 8);
    ctx.beginPath();
    ctx.moveTo(0, y);
    ctx.lineTo(w, y);
    ctx.stroke();
  }

  // 중앙 태극 모티프 (매우 흐릿)
  ctx.save();
  ctx.globalAlpha = 0.04;
  const tcx = w / 2;
  const tcy = h * 0.28;
  const tr = Math.min(w, h) * 0.13;
  ctx.fillStyle = '#c8233a';
  ctx.beginPath();
  ctx.arc(tcx, tcy, tr, -Math.PI / 2, Math.PI / 2);
  ctx.arc(tcx, tcy - tr / 2, tr / 2, Math.PI / 2, -Math.PI / 2, true);
  ctx.arc(tcx, tcy + tr / 2, tr / 2, -Math.PI / 2, Math.PI / 2);
  ctx.fill();
  ctx.fillStyle = '#2a4a8a';
  ctx.beginPath();
  ctx.arc(tcx, tcy, tr, Math.PI / 2, -Math.PI / 2);
  ctx.arc(tcx, tcy + tr / 2, tr / 2, -Math.PI / 2, Math.PI / 2, true);
  ctx.arc(tcx, tcy - tr / 2, tr / 2, Math.PI / 2, -Math.PI / 2);
  ctx.fill();
  ctx.restore();

  // 바닥 중앙 강조 (조명 효과)
  const spot = ctx.createRadialGradient(w / 2, h * 0.78, 20, w / 2, h * 0.78, w * 0.35);
  spot.addColorStop(0, 'rgba(212, 184, 122, 0.10)');
  spot.addColorStop(1, 'rgba(212, 184, 122, 0)');
  ctx.fillStyle = spot;
  ctx.fillRect(0, 0, w, h);
}

// ====================================================================
// 위치 이동: world 좌표 → canvas 좌표 변환
// FOOT_TRAIL의 누적 위치(world)를 stage 영역에 맞춰 스케일
// ====================================================================
function computeStageBounds() {
  // FOOT_TRAIL 전체 범위를 한 번만 계산
  const xs = FOOT_TRAIL.map(p => p.x);
  const ys = FOOT_TRAIL.map(p => p.y);
  return {
    minX: Math.min(...xs), maxX: Math.max(...xs),
    minY: Math.min(...ys), maxY: Math.max(...ys),
  };
}
const STAGE_BOUNDS = computeStageBounds();

function getCurrentWorldPos(formIdx, formT) {
  // 동작이 진행되면서 위치도 보간: 시작 위치(FOOT_TRAIL[formIdx]) → 끝 위치(FOOT_TRAIL[formIdx+1])
  const a = FOOT_TRAIL[formIdx];
  const b = FOOT_TRAIL[Math.min(formIdx + 1, FOOT_TRAIL.length - 1)];
  const eased = easeInOutCubic(formT);
  return {
    x: lerp(a.x, b.x, eased),
    y: lerp(a.y, b.y, eased),
  };
}

function worldToCanvas(worldX, worldY, frame, figScale) {
  // 인물이 차지하는 영역(anchor=발 기준 위로 머리까지 165, 옆 30, 아래 발 끝 12)
  // 이 만큼 frame 안쪽으로 안전 마진을 두고 anchor 가능 영역을 계산
  const figureTop  = 175 * figScale;
  const figureBot  = 14  * figScale;
  const figureSide = 34  * figScale;

  const usableX = frame.x + figureSide;
  const usableY = frame.y + figureTop;
  const usableW = Math.max(20, frame.w - figureSide * 2);
  const usableH = Math.max(20, frame.h - figureTop - figureBot);

  const spanX = (STAGE_BOUNDS.maxX - STAGE_BOUNDS.minX) || 1;
  const spanY = (STAGE_BOUNDS.maxY - STAGE_BOUNDS.minY) || 1;
  // 가로세로 비율 유지 (양 축 fit)
  const scale = Math.min(usableW / spanX, usableH / spanY);

  const centerWorldX = (STAGE_BOUNDS.minX + STAGE_BOUNDS.maxX) / 2;
  const centerWorldY = (STAGE_BOUNDS.minY + STAGE_BOUNDS.maxY) / 2;

  return {
    x: usableX + usableW / 2 + (worldX - centerWorldX) * scale,
    y: usableY + usableH / 2 + (worldY - centerWorldY) * scale,
    scale: scale,
  };
}

// ====================================================================
// 도장 바닥 — 2:1 letterbox frame 내부에만 그림
// ====================================================================
function drawDojangFloor(ctx, frame, fullW, fullH) {
  // letterbox 영역(프레임 바깥)은 짙은 우드 브라운
  ctx.fillStyle = '#1a120a';
  ctx.fillRect(0, 0, fullW, fullH);

  // 도장 frame 내부: 마루바닥 느낌의 노란/황갈색 그라데이션
  const cxF = frame.x + frame.w / 2;
  const cyF = frame.y + frame.h * 0.6;
  const grad = ctx.createRadialGradient(cxF, cyF, 60, cxF, cyF, Math.max(frame.w, frame.h) * 0.7);
  grad.addColorStop(0, '#e0b870');   // 밝은 원목 (조명 받는 중앙)
  grad.addColorStop(0.6, '#cba262');  // 중간 원목
  grad.addColorStop(1, '#a8854e');   // 가장자리 짙은 원목
  ctx.fillStyle = grad;
  ctx.fillRect(frame.x, frame.y, frame.w, frame.h);

  // 마루 널판 결 (가로 줄무늬 + 세로 판 구분으로 나무 질감)
  ctx.strokeStyle = 'rgba(90, 60, 25, 0.18)';
  ctx.lineWidth = 1;
  const stepX = frame.w / 8;
  const stepY = frame.h / 8;
  for (let i = 1; i < 8; i++) {
    const x = frame.x + i * stepX;
    ctx.beginPath();
    ctx.moveTo(x, frame.y);
    ctx.lineTo(x, frame.y + frame.h);
    ctx.stroke();
  }
  for (let i = 1; i < 8; i++) {
    const y = frame.y + i * stepY;
    ctx.beginPath();
    ctx.moveTo(frame.x, y);
    ctx.lineTo(frame.x + frame.w, y);
    ctx.stroke();
  }
  // 널판 사이 잔결(나뭇결 느낌의 가로 미세선)
  ctx.strokeStyle = 'rgba(70, 45, 18, 0.10)';
  ctx.lineWidth = 0.6;
  for (let i = 0; i < 8; i++) {
    const y = frame.y + i * stepY + stepY * 0.5;
    ctx.beginPath();
    ctx.moveTo(frame.x, y);
    ctx.lineTo(frame.x + frame.w, y);
    ctx.stroke();
  }

  // 중앙 십자 (짙은 적갈색으로 또렷하게)
  ctx.strokeStyle = 'rgba(80, 45, 15, 0.35)';
  ctx.lineWidth = 1.5;
  ctx.beginPath();
  ctx.moveTo(frame.x + frame.w / 2, frame.y);
  ctx.lineTo(frame.x + frame.w / 2, frame.y + frame.h);
  ctx.moveTo(frame.x, frame.y + frame.h / 2);
  ctx.lineTo(frame.x + frame.w, frame.y + frame.h / 2);
  ctx.stroke();

  // 프레임 외곽선 (짙은 우드 브라운)
  ctx.strokeStyle = 'rgba(60, 35, 12, 0.55)';
  ctx.lineWidth = 2;
  ctx.strokeRect(frame.x, frame.y, frame.w, frame.h);

  // 한자 방위표시 (프레임 바깥쪽 가장자리, 짙은 갈색 배경 위라 밝은 톤 유지)
  ctx.font = '600 17px "Noto Serif KR", serif';
  ctx.textAlign = 'center';
  ctx.textBaseline = 'middle';
  ctx.fillStyle = 'rgba(212, 184, 122, 0.5)';
  ctx.fillText('北', frame.x + frame.w / 2, frame.y - 12);
  ctx.fillText('南', frame.x + frame.w / 2, frame.y + frame.h + 14);
  ctx.fillText('西', frame.x - 14, frame.y + frame.h / 2);
  ctx.fillText('東', frame.x + frame.w + 14, frame.y + frame.h / 2);
}

function drawTrail(ctx, currentFormIdx, currentT, frame, figScale) {
  // 지금까지 지나온 발자국 경로를 바닥에 표시
  const points = [];
  for (let i = 0; i <= currentFormIdx; i++) {
    const wp = FOOT_TRAIL[i];
    const c = worldToCanvas(wp.x, wp.y, frame, figScale);
    points.push({ x: c.x, y: c.y, idx: i });
  }
  // 현재 진행중인 위치
  if (currentT > 0 && currentFormIdx < FOOT_TRAIL.length - 1) {
    const cur = getCurrentWorldPos(currentFormIdx, currentT);
    const c = worldToCanvas(cur.x, cur.y, frame, figScale);
    points.push({ x: c.x, y: c.y, current: true });
  }

  if (points.length < 2) return;

  // 트레일 선 (점선) — 밝은 마루바닥 위에서 또렷이 보이는 짙은 적갈색/먹색
  ctx.strokeStyle = 'rgba(60, 30, 12, 0.55)';
  ctx.lineWidth = 2.16;
  ctx.setLineDash([4.8, 4.8]);
  ctx.beginPath();
  ctx.moveTo(points[0].x, points[0].y);
  for (let i = 1; i < points.length; i++) ctx.lineTo(points[i].x, points[i].y);
  ctx.stroke();
  ctx.setLineDash([]);

  // 지나온 위치 점 + 번호
  for (let i = 0; i < points.length - 1; i++) {
    const p = points[i];
    ctx.fillStyle = 'rgba(60, 30, 12, 0.65)';
    ctx.beginPath();
    ctx.arc(p.x, p.y, 3.6, 0, Math.PI * 2);
    ctx.fill();
    ctx.font = '11px sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'top';
    ctx.fillStyle = 'rgba(40, 20, 8, 0.75)';
    if (i > 0) ctx.fillText(String(i), p.x, p.y + 6);
  }
}

// ====================================================================
// facing 기반 인물 렌더링 분기
// 0° (동, 우향) / 90° (남, 정면) / 180° (서, 좌향, mirror) / 270° (북, 후면)
// 사선 각도(45°, 60° 등)는 가까운 4방위 두 개 사이를 보간
// ====================================================================
function getFacingView(facing) {
  // facing을 0~360 정규화
  let f = ((facing % 360) + 360) % 360;
  // 4방위 정의: 0=east, 90=south, 180=west, 270=north
  // 가장 가까운 방위 + 두 방위 사이 가중치
  if (f <= 45) return { primary: 'east', secondary: 'south', blend: f / 90 };
  if (f <= 135) return { primary: 'south', secondary: f < 90 ? 'east' : 'west', blend: Math.abs(f - 90) / 90 };
  if (f <= 225) return { primary: 'west', secondary: f < 180 ? 'south' : 'north', blend: Math.abs(f - 180) / 90 };
  if (f <= 315) return { primary: 'north', secondary: f < 270 ? 'west' : 'east', blend: Math.abs(f - 270) / 90 };
  return { primary: 'east', secondary: 'north', blend: (360 - f) / 90 };
}

// 정면/후면 간략 도식
function drawFigureFront(ctx, cx, cy, pose, scale, isBack) {
  ctx.save();
  ctx.translate(cx, cy);
  ctx.scale(scale, scale);

  // 정면/후면 공통: 대칭 실루엣
  const hipY = -2;
  const chestY = -90;
  const shoulderY = -120;
  const headY = -150;

  // 하카마 (정면 사다리꼴, 대칭)
  ctx.fillStyle = '#16161e';
  ctx.beginPath();
  ctx.moveTo(-26, hipY - 10);
  ctx.lineTo(26, hipY - 10);
  ctx.lineTo(32, 0);
  ctx.lineTo(-32, 0);
  ctx.closePath();
  ctx.fill();
  // 하카마 음영
  const grad = ctx.createLinearGradient(-32, 0, 32, 0);
  grad.addColorStop(0, 'rgba(0,0,0,0.5)');
  grad.addColorStop(0.5, 'rgba(0,0,0,0)');
  grad.addColorStop(1, 'rgba(0,0,0,0.5)');
  ctx.fillStyle = grad;
  ctx.beginPath();
  ctx.moveTo(-26, hipY - 10);
  ctx.lineTo(26, hipY - 10);
  ctx.lineTo(32, 0);
  ctx.lineTo(-32, 0);
  ctx.closePath();
  ctx.fill();
  // 주름
  ctx.strokeStyle = '#0a0a10';
  ctx.lineWidth = 1;
  for (let i = 1; i < 5; i++) {
    const xTop = -26 + (52 * i / 5);
    const xBot = -32 + (64 * i / 5);
    ctx.beginPath();
    ctx.moveTo(xTop, hipY - 8);
    ctx.lineTo(xBot, -2);
    ctx.stroke();
  }
  // 허리띠
  ctx.fillStyle = '#0a0a10';
  ctx.fillRect(-26, hipY - 14, 52, 5);

  // 두 발 (정면, 둥근 타원)
  for (const fx of [-12, 12]) {
    ctx.fillStyle = '#e8d8c0';
    ctx.strokeStyle = '#3a2a1a';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.ellipse(fx, -2, 7, 5, 0, 0, Math.PI * 2);
    ctx.fill();
    ctx.stroke();
    ctx.fillStyle = 'rgba(255, 248, 230, 0.22)';
    ctx.beginPath();
    ctx.ellipse(fx, -3, 4, 2, 0, 0, Math.PI * 2);
    ctx.fill();
  }

  // 상의 (정면 대칭, V넥)
  ctx.fillStyle = '#1f1f28';
  ctx.beginPath();
  ctx.moveTo(-22, shoulderY + 2);
  ctx.lineTo(22, shoulderY + 2);
  ctx.lineTo(26, chestY);
  ctx.lineTo(22, hipY - 10);
  ctx.lineTo(-22, hipY - 10);
  ctx.lineTo(-26, chestY);
  ctx.closePath();
  ctx.fill();
  // V넥 (정면일 때만)
  if (!isBack) {
    ctx.strokeStyle = '#3a3a48';
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.moveTo(-12, shoulderY + 6);
    ctx.lineTo(0, chestY + 14);
    ctx.lineTo(12, shoulderY + 6);
    ctx.stroke();
  }

  // 두 팔 (정면일 때 검 그립으로 앞에 모음)
  if (!isBack) {
    // 양팔 — 검을 가운데로 잡음
    ctx.strokeStyle = '#1f1f28';
    ctx.lineCap = 'round';
    // 왼팔
    ctx.beginPath();
    ctx.moveTo(-18, shoulderY + 4);
    ctx.lineTo(-8, -50);
    ctx.lineTo(-3, -35);
    ctx.stroke();
    // 오른팔
    ctx.beginPath();
    ctx.moveTo(18, shoulderY + 4);
    ctx.lineTo(8, -50);
    ctx.lineTo(3, -35);
    ctx.stroke();
    // 양손
    ctx.fillStyle = '#e8d8c0';
    ctx.strokeStyle = '#3a2a1a';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.arc(-3, -35, 4, 0, Math.PI * 2);
    ctx.fill();
    ctx.stroke();
    ctx.beginPath();
    ctx.arc(3, -35, 4, 0, Math.PI * 2);
    ctx.fill();
    ctx.stroke();

    // 검 (정면: 카메라 쪽으로 향해 짧게 보임)
    // 칼날을 살짝 비스듬하게 (pose의 swordAngle 활용)
    const ang = (pose.swordAngle || -90) * Math.PI / 180;
    const swLen = (pose.swordLength || 80) * 0.45; // 단축 표시
    ctx.save();
    ctx.translate(0, -35);
    ctx.rotate(ang);
    // 칼자루
    ctx.fillStyle = '#1a1410';
    ctx.fillRect(-3, -2, 16, 4);
    // 코등이
    ctx.fillStyle = '#6a5a40';
    ctx.beginPath();
    ctx.ellipse(13, 0, 2, 5, 0, 0, Math.PI * 2);
    ctx.fill();
    // 칼날
    ctx.fillStyle = '#c8c4b8';
    ctx.fillRect(15, -1.5, swLen, 3);
    // 칼끝 하이라이트
    ctx.fillStyle = 'rgba(255,255,255,0.4)';
    ctx.fillRect(15, -1.5, swLen, 1);
    ctx.restore();
  }

  // 머리
  ctx.fillStyle = isBack ? '#1a0f08' : '#e8d8c0';
  ctx.strokeStyle = '#3a2a1a';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.arc(0, headY, 14, 0, Math.PI * 2);
  ctx.fill();
  ctx.stroke();
  // 머리카락
  ctx.fillStyle = '#1a0f08';
  ctx.beginPath();
  ctx.arc(0, headY - 3, 13, Math.PI, 0);
  ctx.fill();

  if (!isBack) {
    // 양 눈
    ctx.fillStyle = '#1a0f08';
    ctx.beginPath();
    ctx.arc(-5, headY + 1, 1.4, 0, Math.PI * 2);
    ctx.fill();
    ctx.beginPath();
    ctx.arc(5, headY + 1, 1.4, 0, Math.PI * 2);
    ctx.fill();
    // 입 (희미)
    ctx.strokeStyle = '#7a5a4a';
    ctx.lineWidth = 0.8;
    ctx.beginPath();
    ctx.moveTo(-3, headY + 6);
    ctx.lineTo(3, headY + 6);
    ctx.stroke();
  } else {
    // 후두부 — 머리카락 전체
    ctx.fillStyle = '#1a0f08';
    ctx.beginPath();
    ctx.arc(0, headY, 14, 0, Math.PI * 2);
    ctx.fill();
  }

  ctx.restore();
}

// ====================================================================
// 메인 인물 렌더 분기: facing 따라 측면 / 정면 / 후면 선택
// ====================================================================
function drawFigureFacing(ctx, cx, cy, pose, scale, facing) {
  const view = getFacingView(facing);

  if (view.primary === 'east') {
    // 측면 뷰 (기존 그대로) — 가까운 보조 방위에 따라 살짝 압축할 수도 있음
    const squeeze = view.blend * 0.3; // 0~0.3 (남/북 방향으로 회전 시작 시 압축)
    ctx.save();
    ctx.translate(cx, cy);
    ctx.scale(1 - squeeze, 1);
    drawFigure(ctx, 0, 0, pose, scale);
    ctx.restore();
  } else if (view.primary === 'west') {
    // 측면 뷰를 좌우 반전
    const squeeze = view.blend * 0.3;
    ctx.save();
    ctx.translate(cx, cy);
    ctx.scale(-(1 - squeeze), 1);
    drawFigure(ctx, 0, 0, pose, scale);
    ctx.restore();
  } else if (view.primary === 'south') {
    // 정면 (카메라 방향) — 사용자가 인물의 얼굴을 봄
    drawFigureFront(ctx, cx, cy, pose, scale, false);
  } else {
    // 후면 (북, 카메라 반대)
    drawFigureFront(ctx, cx, cy, pose, scale, true);
  }
}

// ====================================================================
// 애니메이션 상태 + 메인 루프
// ====================================================================
const state = {
  formIdx: 0,
  formT: 0,
  playing: true,
  speed: 1,
  loop: true,
  lastTime: 0,
};

function drawScene() {
  const rect = stageCanvas.getBoundingClientRect();
  const w = rect.width;
  const h = rect.height;
  stageCtx.clearRect(0, 0, w, h);

  // ─── 4:3 letterbox 프레임 영역 계산 ───
  // 가로 ÷ 세로 = 4/3 가 되는 최대 사각형을 캔버스 중앙에 배치
  const FRAME_RATIO = 1;
  let frameW, frameH;
  if (w / h > FRAME_RATIO) {
    // 캔버스가 너무 가로로 김 → 높이에 맞춤
    frameH = h * 0.96; // 약간의 외곽 여유
    frameW = frameH * FRAME_RATIO;
  } else {
    // 캔버스가 정사각 또는 세로형 → 폭에 맞춤
    frameW = w * 0.96;
    frameH = frameW / FRAME_RATIO;
  }
  const frame = {
    x: (w - frameW) / 2,
    y: (h - frameH) / 2,
    w: frameW,
    h: frameH,
  };

  // 인물 스케일: 프레임의 짧은 변 기준 (인물 자연 높이 ~165px)
  // 기존 비율(45.6%)에서 1.2배 확대 적용, 정사각 프레임이므로 min(w,h) 사용
  const figScale = (Math.min(frame.w, frame.h) * 0.5472) / 165; // 0.456 × 1.2

  // ─── 1. 도장 바닥 ───
  drawDojangFloor(stageCtx, frame, w, h);

  // ─── 2. 발자국 트레일 ───
  drawTrail(stageCtx, state.formIdx, state.formT, frame, figScale);

  // ─── 3. 인물 위치 + 방향 ───
  const { pose, facing } = getCurrentPose(state.formIdx, state.formT);
  const worldPos = getCurrentWorldPos(state.formIdx, state.formT);
  const canvasPos = worldToCanvas(worldPos.x, worldPos.y, frame, figScale);

  // ─── 4. 발 아래 그림자 (먼저, 인물보다 뒤에) ───
  stageCtx.fillStyle = 'rgba(0, 0, 0, 0.45)';
  stageCtx.beginPath();
  stageCtx.ellipse(canvasPos.x, canvasPos.y + 3 * figScale, 30 * figScale, 7 * figScale, 0, 0, Math.PI * 2);
  stageCtx.fill();

  // ─── 5. 인물 렌더링 (facing 방향 분기) ───
  drawFigureFacing(stageCtx, canvasPos.x, canvasPos.y, pose, figScale, facing);
}

function tick(now) {
  if (!state.lastTime) state.lastTime = now;
  const dt = now - state.lastTime;
  state.lastTime = now;

  if (state.playing) {
    const form = FORMS[state.formIdx];
    state.formT += (dt / form.duration) * state.speed;
    if (state.formT >= 1) {
      if (state.formIdx < FORMS.length - 1) {
        state.formIdx++;
        state.formT = 0;
        updateUI();
      } else if (state.loop) {
        state.formIdx = 0;
        state.formT = 0;
        updateUI();
      } else {
        state.formT = 1;
        state.playing = false;
        document.getElementById('btn-play').textContent = '▶';
      }
    }
  }

  drawScene();
  updateProgress();
  requestAnimationFrame(tick);
}

function updateUI() {
  const form = FORMS[state.formIdx];
  const isFinish = form.nameKo.includes('마무리');
  // 마무리 동작은 번호 대신 '畢'(끝날 필) 표기
  const num = isFinish ? '畢' : String(state.formIdx + 1).padStart(2, '0');
  document.getElementById('tag-hanja-main').textContent = `${form.nameHj} (${form.nameKo})`;
  document.getElementById('tag-num').textContent = num;
  document.getElementById('tag-phase').textContent = form.section;
  document.getElementById('progress-cur').textContent = num;
  // 목록 업데이트
  document.querySelectorAll('.form-list li[data-idx]').forEach(li => {
    li.classList.toggle('active', parseInt(li.dataset.idx) === state.formIdx);
  });
  // 활성 항목 스크롤
  const active = document.querySelector('.form-list li.active');
  if (active) active.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
}

function updateProgress() {
  const totalForms = FORMS.length;
  const overall = (state.formIdx + state.formT) / totalForms;
  document.getElementById('progress-fill').style.width = (overall * 100) + '%';
}

// ====================================================================
// UI 초기화
// ====================================================================
function buildFormList() {
  const ul = document.getElementById('form-list');
  let lastSection = null;
  FORMS.forEach((f, i) => {
    if (f.section !== lastSection) {
      const div = document.createElement('li');
      div.className = 'section-divider';
      div.innerHTML = `<span class="label">${f.section}</span>`;
      ul.appendChild(div);
      lastSection = f.section;
    }
    const li = document.createElement('li');
    li.dataset.idx = i;
    if (i === 0) li.classList.add('active');
    li.innerHTML = `
      <span class="num">${String(i + 1).padStart(2, '0')}</span>
      <div class="names">
        <div class="ko">${f.nameKo}</div>
        <div class="li-desc">${f.desc}</div>
      </div>
    `;
    li.addEventListener('click', () => {
      state.formIdx = i;
      state.formT = 0;
      updateUI();
    });
    ul.appendChild(li);
  });
}

function buildProgressMarks() {
  const marks = document.getElementById('progress-marks');
  const total = FORMS.length;
  let lastSection = null;
  FORMS.forEach((f, i) => {
    const div = document.createElement('div');
    div.className = 'mark' + (f.section !== lastSection ? ' section' : '');
    div.style.left = (i / total * 100) + '%';
    marks.appendChild(div);
    lastSection = f.section;
  });
}

// ----- 컨트롤 핸들러 -----
document.getElementById('btn-play').addEventListener('click', () => {
  state.playing = !state.playing;
  document.getElementById('btn-play').textContent = state.playing ? '⏸' : '▶';
});
document.getElementById('btn-prev').addEventListener('click', () => {
  state.formIdx = Math.max(0, state.formIdx - 1);
  state.formT = 0;
  updateUI();
});
document.getElementById('btn-next').addEventListener('click', () => {
  state.formIdx = Math.min(FORMS.length - 1, state.formIdx + 1);
  state.formT = 0;
  updateUI();
});
document.getElementById('btn-first').addEventListener('click', () => {
  state.formIdx = 0;
  state.formT = 0;
  updateUI();
});
document.getElementById('btn-last').addEventListener('click', () => {
  state.formIdx = FORMS.length - 1;
  state.formT = 0;
  updateUI();
});
document.querySelectorAll('.speed-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    state.speed = parseFloat(btn.dataset.speed);
    document.querySelectorAll('.speed-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  });
});
document.getElementById('loop-toggle').addEventListener('change', e => {
  state.loop = e.target.checked;
});
document.getElementById('progress-bar').addEventListener('click', e => {
  const rect = e.currentTarget.getBoundingClientRect();
  const x = (e.clientX - rect.left) / rect.width;
  const total = FORMS.length;
  const target = x * total;
  state.formIdx = Math.min(FORMS.length - 1, Math.floor(target));
  state.formT = target - state.formIdx;
  updateUI();
});

// 키보드 단축키
document.addEventListener('keydown', e => {
  if (e.key === ' ') { e.preventDefault(); document.getElementById('btn-play').click(); }
  else if (e.key === 'ArrowLeft') document.getElementById('btn-prev').click();
  else if (e.key === 'ArrowRight') document.getElementById('btn-next').click();
  else if (e.key === 'Home') document.getElementById('btn-first').click();
  else if (e.key === 'End') document.getElementById('btn-last').click();
});

// 초기화
document.getElementById('tag-total').textContent = FORM_COUNT;
document.getElementById('progress-total').textContent = FORM_COUNT;
buildFormList();
buildProgressMarks();
updateUI();
document.getElementById('btn-play').textContent = '⏸';
requestAnimationFrame(tick);
</script>
</body>
</html>
